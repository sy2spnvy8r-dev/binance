SOURCE_TYPE=binance_copy_trade_lead_positions
DRY_RUN=false
MONITOR_EVENTS=copyTradeLeadPositionsSnapshot
SYMBOL_ALLOWLIST=
MESSAGE_PREFIX=[Binance Monitor]
